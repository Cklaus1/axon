// Phase 27: Advanced loops — break, continue, nested loops, while-style via for.

// ── break: early exit from for loop ──────────────────────────────────────────

fn find_first_over(limit: i64, threshold: i64) -> i64 {
    let found = -1
    for i in 0..limit {
        if i * i > threshold {
            found = i
            break
        }
    }
    found
}

fn test_break_early_exit() -> bool {
    // first i where i*i > 10 is i=4 (16 > 10)
    find_first_over(100, 10) == 4
}

// ── continue: skip iteration ──────────────────────────────────────────────────

fn sum_odds(n: i64) -> i64 {
    let total = 0
    for i in 0..n {
        if i - (i / 2) * 2 == 0 {
            continue
        }
        total = total + i
    }
    total
}

fn test_continue_skip_evens() -> bool {
    // sum of odd numbers in 0..10: 1+3+5+7+9 = 25
    sum_odds(10) == 25
}

// ── nested loop with break ────────────────────────────────────────────────────

fn count_pairs_below(n: i64, limit: i64) -> i64 {
    let count = 0
    for i in 0..n {
        for j in 0..n {
            if i * j >= limit {
                break
            }
            count = count + 1
        }
    }
    count
}

fn test_nested_break() -> bool {
    // For each i in 0..5, count j in 0..5 where i*j < 6.
    // i=0: j=0..5 (all: 5), i=1: 0..6 capped at 5 (5), i=2: 0..3 (3), i=3: 0..2 (2), i=4: 0..2 (2) → 5+5+3+2+2=17
    count_pairs_below(5, 6) == 17
}

// ── continue in nested loop ───────────────────────────────────────────────────

fn sum_non_multiples(n: i64, divisor: i64) -> i64 {
    let total = 0
    for i in 0..n {
        if i - (i / divisor) * divisor == 0 {
            continue
        }
        total = total + i
    }
    total
}

fn test_continue_multiples() -> bool {
    // 0..10 skipping multiples of 3: 1+2+4+5+7+8 = 27
    sum_non_multiples(10, 3) == 27
}

// ── break with accumulator pattern ───────────────────────────────────────────

fn prefix_sum_until(vals_len: i64, threshold: i64) -> i64 {
    let sum = 0
    for i in 0..vals_len {
        sum = sum + i
        if sum >= threshold {
            break
        }
    }
    sum
}

fn test_break_accumulator() -> bool {
    // 0+1+2+3+4+5 = 15; first time sum >= 10 is after adding 4 (sum=10)
    prefix_sum_until(100, 10) == 10
}

// ── loop index after break ────────────────────────────────────────────────────

fn first_square_exceeding(threshold: i64) -> i64 {
    let result = -1
    for i in 1..1000 {
        if i * i > threshold {
            result = i * i
            break
        }
    }
    result
}

fn test_break_result_capture() -> bool {
    // first i where i*i > 50: i=8 (64 > 50)
    first_square_exceeding(50) == 64
}

fn main() -> i64 {
    let s1 = if test_break_early_exit()    { 1 } else { 0 }
    let s2 = if test_continue_skip_evens() { 1 } else { 0 }
    let s3 = if test_nested_break()        { 1 } else { 0 }
    let s4 = if test_continue_multiples()  { 1 } else { 0 }
    let s5 = if test_break_accumulator()   { 1 } else { 0 }
    let s6 = if test_break_result_capture(){ 1 } else { 0 }
    s1 + s2 + s3 + s4 + s5 + s6
}
