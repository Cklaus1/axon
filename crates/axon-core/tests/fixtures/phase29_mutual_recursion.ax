// Phase 29: Mutual recursion вЂ” functions that call each other,
//           exercising the resolver's two-pass top-level collection.

// в”Ђв”Ђ Classic is_even / is_odd в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn is_even(n: i64) -> bool {
    if n == 0 { true }
    else { is_odd(n - 1) }
}

fn is_odd(n: i64) -> bool {
    if n == 0 { false }
    else { is_even(n - 1) }
}

fn test_even_odd() -> bool {
    is_even(0) &&
    !is_odd(0) &&
    !is_even(1) &&
    is_odd(1) &&
    is_even(4) &&
    is_odd(7) &&
    !is_even(9)
}

// в”Ђв”Ђ Mutual recursion with accumulator (Collatz-style) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn collatz_even(n: i64, steps: i64) -> i64 {
    if n == 1 { steps }
    else { collatz_odd(n / 2, steps + 1) }
}

fn collatz_odd(n: i64, steps: i64) -> i64 {
    if n == 1 { steps }
    else if is_even(n) { collatz_even(n, steps) }
    else { collatz_even(n * 3 + 1, steps + 1) }
}

fn collatz_steps(n: i64) -> i64 {
    collatz_odd(n, 0)
}

fn test_collatz() -> bool {
    collatz_steps(1) == 0 &&
    collatz_steps(2) == 1 &&   // 2 в†’ 1
    collatz_steps(3) == 7      // 3в†’10в†’5в†’16в†’8в†’4в†’2в†’1
}

// в”Ђв”Ђ Forward reference: use before definition в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn double_then_inc(n: i64) -> i64 {
    inc(double(n))
}

fn double(n: i64) -> i64 { n * 2 }
fn inc(n: i64) -> i64 { n + 1 }

fn test_forward_ref() -> bool {
    double_then_inc(5) == 11   // double(5)=10, inc(10)=11
}

// в”Ђв”Ђ Ackermann (deeply mutual recursion for parser/resolver stress) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn ack(m: i64, n: i64) -> i64 {
    if m == 0 {
        n + 1
    } else if n == 0 {
        ack(m - 1, 1)
    } else {
        ack(m - 1, ack(m, n - 1))
    }
}

fn test_ackermann() -> bool {
    ack(0, 0) == 1 &&
    ack(1, 1) == 3 &&
    ack(2, 2) == 7 &&
    ack(3, 0) == 5
}

// в”Ђв”Ђ Digit-parity: even/odd digit count в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn count_even_digits(n: i64) -> i64 {
    if n == 0 { 0 }
    else {
        let digit = n - (n / 10) * 10
        let rest = count_odd_digits(n / 10)
        if is_even(digit) { rest + 1 } else { rest }
    }
}

fn count_odd_digits(n: i64) -> i64 {
    if n == 0 { 0 }
    else {
        let digit = n - (n / 10) * 10
        let rest = count_even_digits(n / 10)
        if is_odd(digit) { rest + 1 } else { rest }
    }
}

fn test_digit_parity() -> bool {
    // 1234: digits 1(odd),2(even),3(odd),4(even) в†’ 2 even, 2 odd
    count_even_digits(1234) == 2 &&
    count_odd_digits(1234) == 2
}

fn main() -> i64 {
    let s1 = if test_even_odd()     { 1 } else { 0 }
    let s2 = if test_collatz()      { 1 } else { 0 }
    let s3 = if test_forward_ref()  { 1 } else { 0 }
    let s4 = if test_ackermann()    { 1 } else { 0 }
    let s5 = if test_digit_parity() { 1 } else { 0 }
    s1 + s2 + s3 + s4 + s5
}
