// Phase 42: Sorting checks — min/max/median of 3, sort-order validation,
//           clamping, and ordering utilities without arrays.

// ── Min of three ─────────────────────────────────────────────────────────────

fn min3(a: i64, b: i64, c: i64) -> i64 {
    min_i64(a, min_i64(b, c))
}

fn test_min3() -> bool {
    min3(3, 1, 2) == 1 &&
    min3(5, 5, 5) == 5 &&
    min3(-1, 0, 1) == -1 &&
    min3(10, 3, 7) == 3
}

// ── Max of three ─────────────────────────────────────────────────────────────

fn max3(a: i64, b: i64, c: i64) -> i64 {
    max_i64(a, max_i64(b, c))
}

fn test_max3() -> bool {
    max3(3, 1, 2) == 3 &&
    max3(5, 5, 5) == 5 &&
    max3(-1, 0, 1) == 1 &&
    max3(10, 3, 7) == 10
}

// ── Median of three ───────────────────────────────────────────────────────────

fn median3(a: i64, b: i64, c: i64) -> i64 {
    let lo = min_i64(a, b)
    let hi = max_i64(a, b)
    max_i64(lo, min_i64(hi, c))
}

fn test_median3() -> bool {
    median3(1, 2, 3) == 2 &&
    median3(3, 1, 2) == 2 &&
    median3(5, 5, 5) == 5 &&
    median3(10, 1, 7) == 7 &&
    median3(1, 10, 5) == 5
}

// ── Is sorted (ascending) — three elements ────────────────────────────────────

fn is_sorted3(a: i64, b: i64, c: i64) -> bool {
    a <= b && b <= c
}

fn test_is_sorted3() -> bool {
    is_sorted3(1, 2, 3) &&
    is_sorted3(1, 1, 1) &&
    is_sorted3(0, 5, 10) &&
    !is_sorted3(3, 2, 1) &&
    !is_sorted3(1, 3, 2)
}

// ── Clamp to range ─────────────────────────────────────────────────────────────

fn clamp_range(n: i64, lo: i64, hi: i64) -> i64 {
    clamp_i64(n, lo, hi)
}

fn test_clamp_range() -> bool {
    clamp_range(5, 0, 10)  == 5  &&
    clamp_range(-3, 0, 10) == 0  &&
    clamp_range(15, 0, 10) == 10 &&
    clamp_range(0, 0, 0)   == 0
}

// ── Sort three values (return as struct) ──────────────────────────────────────

type Sorted3 = { lo: i64, mid: i64, hi: i64 }

fn sort3(a: i64, b: i64, c: i64) -> Sorted3 {
    Sorted3 {
        lo:  min3(a, b, c),
        mid: median3(a, b, c),
        hi:  max3(a, b, c),
    }
}

fn test_sort3() -> bool {
    let s = sort3(3, 1, 2)
    s.lo == 1 && s.mid == 2 && s.hi == 3
}

fn test_sort3_equal() -> bool {
    let s = sort3(5, 5, 5)
    s.lo == 5 && s.mid == 5 && s.hi == 5
}

fn test_sort3_reversed() -> bool {
    let s = sort3(9, 6, 3)
    s.lo == 3 && s.mid == 6 && s.hi == 9
}

// ── Distance between two values ───────────────────────────────────────────────

fn distance(a: i64, b: i64) -> i64 {
    abs_i64(a - b)
}

fn test_distance() -> bool {
    distance(3, 7)   == 4  &&
    distance(7, 3)   == 4  &&
    distance(-5, 5)  == 10 &&
    distance(0, 0)   == 0
}

fn main() -> i64 {
    let s1 = if test_min3()          { 1 } else { 0 }
    let s2 = if test_max3()          { 1 } else { 0 }
    let s3 = if test_median3()       { 1 } else { 0 }
    let s4 = if test_is_sorted3()    { 1 } else { 0 }
    let s5 = if test_clamp_range()   { 1 } else { 0 }
    let s6 = if test_sort3()         { 1 } else { 0 }
    let s7 = if test_sort3_equal()   { 1 } else { 0 }
    let s8 = if test_sort3_reversed(){ 1 } else { 0 }
    let s9 = if test_distance()      { 1 } else { 0 }
    s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8 + s9
}
