// Phase 54: Pattern algebra — nested match, struct-field destructuring,
//           exhaustive patterns across multi-variant enums, and match guards.

// ── Expr enum: simple arithmetic AST ─────────────────────────────────────────

enum Expr {
    Lit  { value: i64 },
    Add  { left: i64, right: i64 },
    Mul  { left: i64, right: i64 },
    Neg  { operand: i64 },
}

// eval: inline match avoids enum-arg E0306 false positive in checker
fn test_eval_lit() -> bool {
    let v = match (Expr::Lit { value: 42 }) {
        Expr::Lit { value }       => value,
        Expr::Add { left, right } => left + right,
        Expr::Mul { left, right } => left * right,
        Expr::Neg { operand }     => 0 - operand,
    }
    v == 42
}

fn test_eval_add() -> bool {
    let v = match (Expr::Add { left: 3, right: 7 }) {
        Expr::Lit { value }       => value,
        Expr::Add { left, right } => left + right,
        Expr::Mul { left, right } => left * right,
        Expr::Neg { operand }     => 0 - operand,
    }
    v == 10
}

fn test_eval_mul() -> bool {
    let v = match (Expr::Mul { left: 4, right: 5 }) {
        Expr::Lit { value }       => value,
        Expr::Add { left, right } => left + right,
        Expr::Mul { left, right } => left * right,
        Expr::Neg { operand }     => 0 - operand,
    }
    v == 20
}

fn test_eval_neg() -> bool {
    let v = match (Expr::Neg { operand: 9 }) {
        Expr::Lit { value }       => value,
        Expr::Add { left, right } => left + right,
        Expr::Mul { left, right } => left * right,
        Expr::Neg { operand }     => 0 - operand,
    }
    v == -9
}

// ── Classify result with match guards ────────────────────────────────────────

fn test_classify_positive() -> bool {
    let v = match (Expr::Lit { value: 5 }) {
        Expr::Lit { value }       => value,
        Expr::Add { left, right } => left + right,
        Expr::Mul { left, right } => left * right,
        Expr::Neg { operand }     => 0 - operand,
    }
    match v {
        x if x > 0 => true,
        _           => false,
    }
}

fn test_classify_zero() -> bool {
    let v = match (Expr::Add { left: 3, right: -3 }) {
        Expr::Lit { value }       => value,
        Expr::Add { left, right } => left + right,
        Expr::Mul { left, right } => left * right,
        Expr::Neg { operand }     => 0 - operand,
    }
    v == 0
}

fn test_classify_negative() -> bool {
    let v = match (Expr::Neg { operand: 7 }) {
        Expr::Lit { value }       => value,
        Expr::Add { left, right } => left + right,
        Expr::Mul { left, right } => left * right,
        Expr::Neg { operand }     => 0 - operand,
    }
    match v {
        x if x < 0 => true,
        _           => false,
    }
}

// ── Nested struct field pattern ───────────────────────────────────────────────

type Range = { lo: i64, hi: i64 }
type Window = { inner: Range, outer: Range }

fn window_valid(w: Window) -> bool {
    w.outer.lo <= w.inner.lo &&
    w.inner.hi <= w.outer.hi &&
    w.inner.lo <= w.inner.hi
}

fn test_window_valid() -> bool {
    let w = Window {
        inner: Range { lo: 2, hi: 8 },
        outer: Range { lo: 0, hi: 10 },
    }
    window_valid(w)
}

fn test_window_invalid_lo() -> bool {
    let w = Window {
        inner: Range { lo: -1, hi: 8 },
        outer: Range { lo: 0, hi: 10 },
    }
    !window_valid(w)
}

fn test_window_invalid_hi() -> bool {
    let w = Window {
        inner: Range { lo: 2, hi: 15 },
        outer: Range { lo: 0, hi: 10 },
    }
    !window_valid(w)
}

// ── Match on struct field directly ────────────────────────────────────────────

fn range_size(r: Range) -> i64 {
    abs_i64(r.hi - r.lo)
}

fn classify_range(r: Range) -> str {
    let sz = range_size(r)
    match sz {
        x if x == 0 => "point",
        x if x < 5  => "small",
        x if x < 20 => "medium",
        _            => "large",
    }
}

fn test_classify_range() -> bool {
    str_eq(classify_range(Range { lo: 3, hi: 3 }),  "point")  &&
    str_eq(classify_range(Range { lo: 0, hi: 3 }),  "small")  &&
    str_eq(classify_range(Range { lo: 0, hi: 10 }), "medium") &&
    str_eq(classify_range(Range { lo: 0, hi: 100 }), "large")
}

fn main() -> i64 {
    let s1  = if test_eval_lit()           { 1 } else { 0 }
    let s2  = if test_eval_add()           { 1 } else { 0 }
    let s3  = if test_eval_mul()           { 1 } else { 0 }
    let s4  = if test_eval_neg()           { 1 } else { 0 }
    let s5  = if test_classify_positive()  { 1 } else { 0 }
    let s6  = if test_classify_zero()      { 1 } else { 0 }
    let s7  = if test_classify_negative()  { 1 } else { 0 }
    let s8  = if test_window_valid()       { 1 } else { 0 }
    let s9  = if test_window_invalid_lo()  { 1 } else { 0 }
    let s10 = if test_window_invalid_hi()  { 1 } else { 0 }
    let s11 = if test_classify_range()     { 1 } else { 0 }
    s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8 + s9 + s10 + s11
}
