// Phase 59: Nested generics — generic structs, generic functions, nested
//           instantiation (Box<Box<T>>), and mixed concrete/generic usage.

// ── Generic wrapper type ──────────────────────────────────────────────────────

type Box<T> = { value: T }
type Tagged<T> = { item: T, label: str }

fn box_new<T>(v: T) -> Box<T> {
    Box { value: v }
}

fn box_get<T>(b: Box<T>) -> T {
    b.value
}

fn tag_new<T>(item: T, label: str) -> Tagged<T> {
    Tagged { item: item, label: label }
}

// ── Basic Box tests ───────────────────────────────────────────────────────────

fn test_box_i64() -> bool {
    let b = box_new(42)
    box_get(b) == 42
}

fn test_box_bool() -> bool {
    let b = box_new(true)
    box_get(b)
}

fn test_box_zero() -> bool {
    let b = box_new(0)
    box_get(b) == 0
}

// ── Tagged struct tests ───────────────────────────────────────────────────────

fn test_tagged_item() -> bool {
    let t = tag_new(99, "score")
    t.item == 99
}

fn test_tagged_label() -> bool {
    let t = tag_new(42, "answer")
    str_eq(t.label, "answer")
}

// ── Nested Box (Box<Box<T>>) ─────────────────────────────────────────────────

fn test_nested_box() -> bool {
    let inner = box_new(7)
    let outer = box_new(inner)
    box_get(box_get(outer)) == 7
}

fn test_nested_box_bool() -> bool {
    let b = box_new(box_new(false))
    !box_get(box_get(b))
}

// ── Generic identity function ─────────────────────────────────────────────────

fn wrap_and_unwrap<T>(v: T) -> T {
    let b = box_new(v)
    box_get(b)
}

fn test_wrap_unwrap_i64() -> bool {
    wrap_and_unwrap(123) == 123
}

fn test_wrap_unwrap_bool() -> bool {
    wrap_and_unwrap(true)
}

fn main() -> i64 {
    let s1  = if test_box_i64()          { 1 } else { 0 }
    let s2  = if test_box_bool()         { 1 } else { 0 }
    let s3  = if test_box_zero()         { 1 } else { 0 }
    let s4  = if test_tagged_item()      { 1 } else { 0 }
    let s5  = if test_tagged_label()     { 1 } else { 0 }
    let s6  = if test_nested_box()       { 1 } else { 0 }
    let s7  = if test_nested_box_bool()  { 1 } else { 0 }
    let s8  = if test_wrap_unwrap_i64()  { 1 } else { 0 }
    let s9  = if test_wrap_unwrap_bool() { 1 } else { 0 }
    s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8 + s9
}
