// Phase 61: Numeric literal formats

fn test_hex_literals() -> bool {
    let a = 0xFF
    let b = 0xDEAD
    a == 255 && b == 57005
}

fn test_binary_literals() -> bool {
    let a = 0b1010
    let b = 0b11111111
    a == 10 && b == 255
}

fn test_octal_literals() -> bool {
    let a = 0o17
    let b = 0o777
    a == 15 && b == 511
}

fn main() -> i64 {
    let s1 = if test_hex_literals()    { 1 } else { 0 }
    let s2 = if test_binary_literals() { 1 } else { 0 }
    let s3 = if test_octal_literals()  { 1 } else { 0 }
    s1 + s2 + s3
}
