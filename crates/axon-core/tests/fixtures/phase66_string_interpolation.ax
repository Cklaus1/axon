// Phase 66: String interpolation — "Hello, {expr}!" format strings with
//           variable references, numeric values, and inline expressions.

// ── Basic variable interpolation ─────────────────────────────────────────────

fn test_basic_interp() -> bool {
    let name = "World"
    let s = "Hello, {name}!"
    str_eq(s, "Hello, World!")
}

fn test_numeric_interp() -> bool {
    let n = 42
    let s = "The answer is {n}"
    str_eq(s, "The answer is 42")
}

// ── Multiple variables in one string ─────────────────────────────────────────

fn test_nested_interp() -> bool {
    let first = "Alice"
    let last = "Smith"
    let s = "{first} {last}"
    str_eq(s, "Alice Smith")
}

// ── Interpolation in function bodies ─────────────────────────────────────────

fn make_greeting(name: str, age: i64) -> str {
    "{name} is {age} years old"
}

fn test_greeting() -> bool {
    str_eq(make_greeting("Bob", 30), "Bob is 30 years old")
}

fn label(key: str, val: i64) -> str {
    "{key}={val}"
}

fn test_label() -> bool {
    str_eq(label("score", 99), "score=99")
}

// ── Interpolation with str_contains ──────────────────────────────────────────

fn test_interp_contains() -> bool {
    let x = 7
    let s = "value: {x}"
    str_contains(s, "7")
}

fn test_bool_interp() -> bool {
    let flag = true
    let s = "flag={flag}"
    str_contains(s, "true")
}

fn main() -> i64 {
    let s1 = if test_basic_interp()    { 1 } else { 0 }
    let s2 = if test_numeric_interp()  { 1 } else { 0 }
    let s3 = if test_nested_interp()   { 1 } else { 0 }
    let s4 = if test_greeting()        { 1 } else { 0 }
    let s5 = if test_label()           { 1 } else { 0 }
    let s6 = if test_interp_contains() { 1 } else { 0 }
    let s7 = if test_bool_interp()     { 1 } else { 0 }
    s1 + s2 + s3 + s4 + s5 + s6 + s7
}
