// Phase 69: Recursive and self-referential types

// Simple recursive computation (not recursive types, but recursive algorithms on enums)

enum Tree {
    Leaf { val: i64 },
    Node { val: i64, left_val: i64, right_val: i64 },
}

fn tree_sum(t: Tree) -> i64 {
    match t {
        Tree::Leaf { val }                     => val,
        Tree::Node { val, left_val, right_val } => val + left_val + right_val,
    }
}

fn test_tree_leaf() -> bool {
    let t = Tree::Leaf { val: 42 }
    tree_sum(t) == 42
}

fn test_tree_node() -> bool {
    let t = Tree::Node { val: 10, left_val: 3, right_val: 7 }
    tree_sum(t) == 20
}

// Fibonacci via memoization simulation (recursive math)
fn fib(n: i64) -> i64 {
    if n <= 1 { n }
    else { fib(n - 1) + fib(n - 2) }
}

fn test_fibonacci() -> bool {
    fib(0) == 0 &&
    fib(1) == 1 &&
    fib(10) == 55 &&
    fib(15) == 610
}

// Ackermann function (highly recursive)
fn ackermann(m: i64, n: i64) -> i64 {
    if m == 0 {
        n + 1
    } else {
        if n == 0 {
            ackermann(m - 1, 1)
        } else {
            ackermann(m - 1, ackermann(m, n - 1))
        }
    }
}

fn test_ackermann() -> bool {
    ackermann(0, 0) == 1 &&
    ackermann(1, 1) == 3 &&
    ackermann(2, 2) == 7
}

fn main() -> i64 {
    let s1 = if test_tree_leaf()   { 1 } else { 0 }
    let s2 = if test_tree_node()   { 1 } else { 0 }
    let s3 = if test_fibonacci()   { 1 } else { 0 }
    let s4 = if test_ackermann()   { 1 } else { 0 }
    s1 + s2 + s3 + s4
}
