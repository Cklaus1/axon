// Phase 73: Advanced error handling chains — ? propagation, domain errors,
//           chained Results, and error-tagged fallback patterns.

// ── Parse a positive integer from a string ───────────────────────────────────

fn parse_positive(s: str) -> Result<i64, str> {
    let n = parse_int(s)?
    if n > 0 { Ok(n) } else { Err("must be positive") }
}

fn test_parse_positive_ok() -> bool {
    match parse_positive("5") {
        Ok(v)  => v == 5,
        Err(_) => false,
    }
}

fn test_parse_positive_zero() -> bool {
    match parse_positive("0") {
        Ok(_)  => false,
        Err(e) => str_contains(e, "positive"),
    }
}

fn test_parse_positive_neg() -> bool {
    match parse_positive("-3") {
        Ok(_)  => false,
        Err(e) => str_contains(e, "positive"),
    }
}

fn test_parse_positive_bad() -> bool {
    match parse_positive("xyz") {
        Ok(_)  => false,
        Err(_) => true,
    }
}

// ── Double a positive integer ─────────────────────────────────────────────────

fn double_positive(s: str) -> Result<i64, str> {
    let n = parse_positive(s)?
    Ok(n * 2)
}

fn test_chain_ok() -> bool {
    match double_positive("5") {
        Ok(v)  => v == 10,
        Err(_) => false,
    }
}

fn test_chain_parse_err() -> bool {
    match double_positive("bad") {
        Ok(_)  => false,
        Err(_) => true,
    }
}

fn test_chain_domain_err() -> bool {
    match double_positive("-3") {
        Ok(_)  => false,
        Err(e) => str_contains(e, "positive"),
    }
}

// ── Safe square root ──────────────────────────────────────────────────────────

fn safe_sqrt(n: i64) -> Result<i64, str> {
    if n < 0 {
        Err("negative input")
    } else {
        Ok(f64_to_i64(sqrt_f64(i64_to_f64(n))))
    }
}

fn test_safe_sqrt_ok() -> bool {
    match safe_sqrt(25) {
        Ok(v)  => v == 5,
        Err(_) => false,
    }
}

fn test_safe_sqrt_zero() -> bool {
    match safe_sqrt(0) {
        Ok(v)  => v == 0,
        Err(_) => false,
    }
}

fn test_safe_sqrt_neg() -> bool {
    match safe_sqrt(-4) {
        Ok(_)  => false,
        Err(e) => str_contains(e, "negative"),
    }
}

// ── Hypotenuse via chained Results ────────────────────────────────────────────

fn hypotenuse(a: str, b: str) -> Result<i64, str> {
    let ai = parse_positive(a)?
    let bi = parse_positive(b)?
    safe_sqrt(ai * ai + bi * bi)
}

fn test_hypotenuse_ok() -> bool {
    match hypotenuse("3", "4") {
        Ok(v)  => v == 5,
        Err(_) => false,
    }
}

fn test_hypotenuse_bad_a() -> bool {
    match hypotenuse("bad", "4") {
        Ok(_)  => false,
        Err(_) => true,
    }
}

fn test_hypotenuse_neg_b() -> bool {
    match hypotenuse("3", "-4") {
        Ok(_)  => false,
        Err(e) => str_contains(e, "positive"),
    }
}

// ── Result-or-default fallback ────────────────────────────────────────────────

fn result_or_zero(r: Result<i64, str>) -> i64 {
    match r {
        Ok(v)  => v,
        Err(_) => 0,
    }
}

fn test_result_or_ok() -> bool {
    result_or_zero(double_positive("7")) == 14
}

fn test_result_or_err() -> bool {
    result_or_zero(double_positive("bad")) == 0
}

fn main() -> i64 {
    let s1  = if test_parse_positive_ok()    { 1 } else { 0 }
    let s2  = if test_parse_positive_zero()  { 1 } else { 0 }
    let s3  = if test_parse_positive_neg()   { 1 } else { 0 }
    let s4  = if test_parse_positive_bad()   { 1 } else { 0 }
    let s5  = if test_chain_ok()             { 1 } else { 0 }
    let s6  = if test_chain_parse_err()      { 1 } else { 0 }
    let s7  = if test_chain_domain_err()     { 1 } else { 0 }
    let s8  = if test_safe_sqrt_ok()         { 1 } else { 0 }
    let s9  = if test_safe_sqrt_zero()       { 1 } else { 0 }
    let s10 = if test_safe_sqrt_neg()        { 1 } else { 0 }
    let s11 = if test_hypotenuse_ok()        { 1 } else { 0 }
    let s12 = if test_hypotenuse_bad_a()     { 1 } else { 0 }
    let s13 = if test_hypotenuse_neg_b()     { 1 } else { 0 }
    let s14 = if test_result_or_ok()         { 1 } else { 0 }
    let s15 = if test_result_or_err()        { 1 } else { 0 }
    s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8 + s9 + s10 + s11 + s12 + s13 + s14 + s15
}
