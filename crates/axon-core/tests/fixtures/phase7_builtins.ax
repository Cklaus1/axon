// Smoke-test for Phase 7 builtins.
// Must parse and type-check without errors.

fn test_str_len() -> bool {
    str_len("hello") == 5
}

fn test_str_pad_start() -> bool {
    let s = str_pad_start("hi", 5, " ")
    str_len(s) == 5
}

fn test_str_pad_end() -> bool {
    let s = str_pad_end("hi", 5, "-")
    str_len(s) == 5
}

fn test_min_f64() -> bool {
    min_f64(1.0, 2.0) == 1.0
}

fn test_max_f64() -> bool {
    max_f64(1.0, 2.0) == 2.0
}

fn test_clamp_i64() -> bool {
    let a = clamp_i64(10, 0, 5)
    let b = clamp_i64(-1, 0, 5)
    let c = clamp_i64(3, 0, 5)
    a == 5 && b == 0 && c == 3
}

fn test_clamp_f64() -> bool {
    let a = clamp_f64(10.0, 0.0, 5.0)
    let b = clamp_f64(-1.0, 0.0, 5.0)
    a == 5.0 && b == 0.0
}

fn test_parse_bool() -> bool {
    let t = parse_bool("true")
    let f = parse_bool("false")
    let e = parse_bool("maybe")
    let ok_t = match t {
        Ok(_) => 1,
        Err(_) => 0,
    }
    let ok_f = match f {
        Ok(_) => 1,
        Err(_) => 0,
    }
    let ok_e = match e {
        Ok(_) => 0,
        Err(_) => 1,
    }
    ok_t == 1 && ok_f == 1 && ok_e == 1
}

fn test_random_i64() -> bool {
    let r = random_i64(0, 100)
    r >= 0 && r < 100
}

fn test_random_f64() -> bool {
    let r = random_f64()
    r >= 0.0
}

fn main() -> i64 {
    let s1 = if test_str_len() { 1 } else { 0 }
    let s2 = if test_str_pad_start() { 1 } else { 0 }
    let s3 = if test_str_pad_end() { 1 } else { 0 }
    let s4 = if test_min_f64() { 1 } else { 0 }
    let s5 = if test_max_f64() { 1 } else { 0 }
    let s6 = if test_clamp_i64() { 1 } else { 0 }
    let s7 = if test_clamp_f64() { 1 } else { 0 }
    let s8 = if test_parse_bool() { 1 } else { 0 }
    let s9 = if test_random_i64() { 1 } else { 0 }
    let s10 = if test_random_f64() { 1 } else { 0 }
    s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8 + s9 + s10
}
