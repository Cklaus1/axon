// Phase 9: Numeric type conversions, abs, sign, pow, libm math

fn test_i64_to_f64() -> bool {
    let x = i64_to_f64(42);
    x == 42.0
}

fn test_f64_to_i64() -> bool {
    let n = f64_to_i64(3.9);
    n == 3
}

fn test_abs_i64() -> bool {
    abs_i64(-7) == 7 && abs_i64(7) == 7 && abs_i64(0) == 0
}

fn test_abs_f64() -> bool {
    abs_f64(-2.5) == 2.5 && abs_f64(2.5) == 2.5
}

fn test_sign_i64() -> bool {
    sign_i64(-10) == -1 && sign_i64(0) == 0 && sign_i64(5) == 1
}

fn test_pow_i64() -> bool {
    pow_i64(2, 10) == 1024 && pow_i64(3, 0) == 1 && pow_i64(5, 3) == 125
}

fn test_sqrt_f64() -> bool {
    let r = sqrt_f64(9.0);
    r == 3.0
}

fn test_floor_ceil() -> bool {
    floor_f64(2.9) == 2.0 && ceil_f64(2.1) == 3.0
}

fn test_round_f64() -> bool {
    round_f64(2.5) == 3.0 && round_f64(2.4) == 2.0
}

fn main() -> i64 {
    let s1 = if test_i64_to_f64()  { 1 } else { 0 };
    let s2 = if test_f64_to_i64()  { 1 } else { 0 };
    let s3 = if test_abs_i64()     { 1 } else { 0 };
    let s4 = if test_abs_f64()     { 1 } else { 0 };
    let s5 = if test_sign_i64()    { 1 } else { 0 };
    let s6 = if test_pow_i64()     { 1 } else { 0 };
    let s7 = if test_sqrt_f64()    { 1 } else { 0 };
    let s8 = if test_floor_ceil()  { 1 } else { 0 };
    let s9 = if test_round_f64()   { 1 } else { 0 };
    s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8 + s9
}
