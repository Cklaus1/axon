enum Shape { Circle { radius: f64 }, Rect { w: f64, h: f64 }, Point }

fn area(s: Shape) -> f64 {
    match s {
        Shape::Circle { radius } => radius * radius
        Shape::Rect { w, h } => w * h
        _ => 0.0
    }
}

fn main() {
    let c = Shape::Circle { radius: 3.0 }
    println(to_str_f64(area(c)))
}
