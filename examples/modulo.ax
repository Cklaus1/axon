fn is_even(n: i64) -> bool {
    n % 2 == 0
}

fn fizzbuzz(n: i64) -> str {
    if n % 15 == 0 {
        "FizzBuzz"
    } else {
        if n % 3 == 0 {
            "Fizz"
        } else {
            if n % 5 == 0 {
                "Buzz"
            } else {
                to_str(n)
            }
        }
    }
}

fn main() {
    let i = 1
    while i <= 15 {
        println(fizzbuzz(i))
        i = i + 1
    }
}
